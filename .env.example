# ─── .env.example ────────────────────────────────────────────────────────────
# Copiar a .env y completar con valores reales
# NUNCA commitear .env al repositorio

# ── Redes ─────────────────────────────────────────────────────────────────────

ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ── Deployer ──────────────────────────────────────────────────────────────────
# En producción usar hardware wallet — nunca clave en texto plano

DEPLOYER_PRIVATE_KEY=0x_TU_CLAVE_PRIVADA_AQUI

# ── Verificación ──────────────────────────────────────────────────────────────

ARBISCAN_API_KEY=TU_ARBISCAN_API_KEY
OPTIMISM_API_KEY=TU_OPTIMISM_API_KEY
ETHERSCAN_API_KEY=TU_ETHERSCAN_API_KEY

# ── Gas Reporter ──────────────────────────────────────────────────────────────

REPORT_GAS=false
COINMARKETCAP_API_KEY=TU_CMC_API_KEY
GAS_REPORT_FILE=                          # dejar vacío para stdout

# ── The Graph ─────────────────────────────────────────────────────────────────

SUBGRAPH_DEPLOY_KEY=TU_GRAPH_DEPLOY_KEY
SUBGRAPH_NAME=cisnerosmusic/fmd-dao

# ── Chainlink VRF ─────────────────────────────────────────────────────────────

CHAINLINK_VRF_COORDINATOR_ARBITRUM=0x41034678D6C633D8a95c75e1138A360a28bA15d1
CHAINLINK_KEY_HASH_ARBITRUM=0x72d2b016bb5b62912afea355ebf33b91319f828a4b86d4ab7f...
CHAINLINK_SUBSCRIPTION_ID=

# ── Addresses desplegados (completar tras deploy) ─────────────────────────────

GOVERNANCE_PARAMS_ADDRESS=
REPUTATION_MODULE_ADDRESS=
FMD_DAO_CORE_ADDRESS=
ORACLE_REGISTRY_ADDRESS=
ORACLE_ROUTER_ADDRESS=
ORACLE_DISPUTE_ADDRESS=
ORACLE_SCHEDULER_ADDRESS=
IMMUNITY_CORE_ADDRESS=
